{
  "archetypes": {
    "content-article": "Text-heavy pages — news homepages, editorials, blog feeds. Tests scroll performance, CLS from lazy-loaded ads and images, TBT from third-party scripts, and typography/readability rendering.",
    "search-results": "Query input paired with filterable, sortable result lists. Tests input responsiveness (INP), result-list rendering speed, filter/sort interaction latency, and pagination or infinite-scroll mechanics.",
    "product-detail": "Single-item pages with rich media, specifications, reviews, and CTAs. Tests LCP for hero images, image carousel and gallery interactions, CTA responsiveness, and layout stability under dynamic content loading.",
    "listing-feed": "Grids, feeds, and directories displaying multiple items (social posts, designs, products). Tests lazy loading, infinite scroll, card/tile rendering performance, CLS from deferred images, and virtualization.",
    "landing-marketing": "Hero-driven brand and SaaS pages with animations and conversion CTAs. Tests FCP/LCP above the fold, animation jank, CLS from late-loading hero assets, and overall first-impression rendering speed.",
    "interactive-tool": "Dashboards, maps, calculators, and data-rich applications. Tests complex JS-driven interactions (INP), data visualization rendering, real-time DOM updates, canvas/WebGL performance, and client-side compute overhead.",
    "media-playback": "Video, audio, and image-dominant pages. Tests media loading strategy, player control responsiveness, gallery/carousel transitions, adaptive streaming, and bandwidth management.",
    "reference-portal": "Documentation hubs, educational platforms, and institutional sites with deep navigation. Tests sidebar/nav interaction latency, content density rendering, progressive disclosure patterns, search within docs, and accessibility compliance."
  },
